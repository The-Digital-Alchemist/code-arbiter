# Copy this file to .env and fill in your keys.

# Which generator to use: claude | openai | stub
GENERATOR_PROVIDER=stub

# Required if GENERATOR_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-key-here
# Optional: override the Claude model (default: claude-opus-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# Required if GENERATOR_PROVIDER=openai
OPENAI_API_KEY=your-openai-key-here
# Optional: override the OpenAI model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini